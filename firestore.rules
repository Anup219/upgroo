rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // By default, deny all client-side access.
    // In Phase 1, all reads and writes will go through Next.js Server Components 
    // and API Routes using the Firebase Admin SDK, which bypasses these rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
